# AI Employee Vault - Git Ignore

# Environment and credentials
.env
.credentials/
*.json
!package.json

# Logs
Logs/*.log
Logs/*.txt
!Logs/.gitkeep

# Session files
*.session
*session*.json

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# IDE
.vscode/
.idea/
*.swp
*.swo

# Temporary files
*.tmp
*.bak
