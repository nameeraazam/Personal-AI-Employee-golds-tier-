# AI Employee Vault Environment Variables
# Copy this file to .env and fill in your credentials

# Gmail API
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=.credentials/gmail_token.json

# LinkedIn API
LINKEDIN_CLIENT_ID=your_client_id
LINKEDIN_CLIENT_SECRET=your_client_secret
LINKEDIN_ACCESS_TOKEN=your_access_token
LINKEDIN_EMAIL=your.email@example.com
LINKEDIN_PASSWORD=your_password

# Facebook Graph API
FACEBOOK_APP_ID=your_app_id
FACEBOOK_ACCESS_TOKEN=your_access_token
FACEBOOK_PAGE_ID=your_page_id

# Odoo ERP
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=your_password

# Watcher Configuration
GMAIL_CHECK_INTERVAL=120
FILE_CHECK_INTERVAL=60
LINKEDIN_CHECK_INTERVAL=60

# Monitoring toggles
LINKEDIN_MONITOR_MESSAGES=true
LINKEDIN_MONITOR_CONNECTIONS=true
LINKEDIN_MONITOR_NOTIFICATIONS=true

# Headless mode (set to true for servers)
LINKEDIN_HEADLESS=false
