# Gold Tier FTE - Environment Configuration
# Facebook: Graph API ONLY (no browser automation)

# =============================================================================
# FACEBOOK GRAPH API (Required)
# =============================================================================
# Get these from Facebook Developers: https://developers.facebook.com/tools/explorer/

# Step 1: Get Access Token
#   1. Go to Graph API Explorer
#   2. Select your app
#   3. Click "Get Token" → "Get User Access Token"
#   4. Add permissions: pages_show_list, pages_read_engagement, pages_manage_posts, etc.
#   5. Generate token and copy it

FACEBOOK_ACCESS_TOKEN=EAAG...your_access_token_here

# Step 2: Get Page ID
#   1. In Graph API Explorer, query: /me/accounts
#   2. Copy the "id" field from your page

FACEBOOK_PAGE_ID=your_page_id_here

# Step 3: Get App Credentials (from App Dashboard)
#   1. Go to https://developers.facebook.com/apps/
#   2. Select your app
#   3. Settings → Basic

FACEBOOK_APP_ID=your_app_id_here
FACEBOOK_APP_SECRET=your_app_secret_here

# API Version (optional - defaults to v18.0)
FACEBOOK_API_VERSION=v18.0

# =============================================================================
# FACEBOOK SETTINGS (Optional)
# =============================================================================

# Monitoring interval in seconds (default: 120)
FACEBOOK_CHECK_INTERVAL=120

# Monitor comments on posts (default: true)
FACEBOOK_MONITOR_COMMENTS=true

# Monitor page messages (default: true)
FACEBOOK_MONITOR_MESSAGES=true

# Monitor posts (default: true)
FACEBOOK_MONITOR_POSTS=true

# Auto-response to comments/messages (default: false)
FACEBOOK_AUTO_RESPONSE=false
FACEBOOK_AUTO_RESPONSE_MESSAGE=Thank you for your message! We will get back to you soon.

# =============================================================================
# ODOO ERP (Optional - for CRM integration)
# =============================================================================

ODOO_URL=http://localhost:8069
ODOO_DB=postgres
ODOO_USERNAME=admin
ODOO_PASSWORD=odoo_secret_password

# Odoo Docker Settings
ODOO_DB_PASSWORD=odoo_secret_password
ODOO_ADMIN_PASSWORD=admin_secret_123
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin_secret_123

# Odoo Sync Settings
ODOO_SYNC_INTERVAL=300
ODOO_AUTO_CREATE_LEADS=true

# =============================================================================
# GOLD TIER ORCHESTRATOR
# =============================================================================

# Enable/Disable integrations
GOLD_ENABLE_FACEBOOK=true
GOLD_ENABLE_ODOO=true

# Auto-sync leads to Odoo CRM
GOLD_AUTO_SYNC_LEADS=true
GOLD_AUTO_CREATE_QUOTATIONS=false

# Cross-posting (post to multiple platforms)
GOLD_CROSS_POST=false

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# Facebook Graph API Setup:
#   1. Go to https://developers.facebook.com/tools/explorer/
#   2. Create/select your app
#   3. Add these permissions:
#      - pages_show_list
#      - read_page_mailboxes
#      - pages_read_engagement
#      - pages_read_user_content
#      - pages_manage_posts
#      - pages_manage_engagement
#   4. Click "Get Token" → "Get User Access Token"
#   5. Generate token and copy FACEBOOK_ACCESS_TOKEN
#   6. Query "/me/accounts" to get FACEBOOK_PAGE_ID
#   7. Copy this file to .env and fill in your values
#
# Test Facebook Connection:
#   python integrations\facebook_integration.py --insights
#
# Start Facebook Monitor:
#   python integrations\facebook_integration.py --monitor
#
# Start Full Gold Tier:
#   python scripts\gold_tier_orchestrator.py --start
#
# =============================================================================
