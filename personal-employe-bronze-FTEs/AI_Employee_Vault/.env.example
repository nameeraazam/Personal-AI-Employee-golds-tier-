# AI Employee - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real credentials to version control

# ===========================================
# Gmail Watcher Configuration
# ===========================================

# Path to Gmail API credentials JSON file
# Download from: https://console.cloud.google.com/apis/credentials
GMAIL_CREDENTIALS_PATH=./.credentials/gmail_credentials.json

# Path to OAuth token file (auto-generated after first auth)
GMAIL_TOKEN_PATH=./.credentials/gmail_token.json

# Watcher settings
GMAIL_CHECK_INTERVAL=120
GMAIL_ONLY_UNREAD=true
GMAIL_ONLY_IMPORTANT=true
GMAIL_MAX_RESULTS=10

# ===========================================
# File System Watcher Configuration
# ===========================================

# Folder to monitor for dropped files
FILE_WATCH_PATH=./drop_folder

# File watcher check interval (seconds)
FILE_CHECK_INTERVAL=60

# File patterns to watch (comma-separated)
FILE_PATTERNS=*.md,*.txt,*.pdf

# ===========================================
# Vault Configuration
# ===========================================

# Path to the AI Employee Vault
VAULT_PATH=./AI_Employee_Vault

# Dashboard update interval (seconds)
DASHBOARD_UPDATE_INTERVAL=5

# ===========================================
# Logging Configuration
# ===========================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path
LOG_PATH=./Logs
