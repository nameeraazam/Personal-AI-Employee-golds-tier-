# LinkedIn API Credentials (Get from https://www.linkedin.com/developer/apps)
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# =============================================================================
# LINKEDIN WATCHER - SILVER TIER
# =============================================================================

# LinkedIn Login Credentials (for Playwright automation)
LINKEDIN_EMAIL=your.email@example.com
LINKEDIN_PASSWORD=your_password_here

# Session Storage Path (saves login session for auto-relogin)
LINKEDIN_SESSION_PATH=./linkedin_session.json

# Monitoring Settings
LINKEDIN_CHECK_INTERVAL=60
LINKEDIN_HEADLESS=false
LINKEDIN_MONITOR_MESSAGES=true
LINKEDIN_MONITOR_CONNECTIONS=true
LINKEDIN_MONITOR_NOTIFICATIONS=true
LINKEDIN_MONITOR_FEED=false
